{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synthpost.local/schemas/thumbnail_brief.schema.json",
  "title": "SynthPost Thumbnail Brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "video_title",
    "episode_headline",
    "topic",
    "main_subjects",
    "story_angle",
    "emotion",
    "assets"
  ],
  "properties": {
    "brief_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9._-]+$"
    },
    "video_title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 180
    },
    "episode_headline": {
      "type": "string",
      "minLength": 5,
      "maxLength": 220
    },
    "topic": {
      "type": "string",
      "enum": [
        "AI",
        "geopolitics",
        "economy",
        "conflict",
        "technology",
        "energy",
        "culture",
        "business",
        "science",
        "policy",
        "finance",
        "infrastructure",
        "health",
        "education"
      ]
    },
    "main_subjects": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "$ref": "#/$defs/subject"
      }
    },
    "story_angle": {
      "type": "string",
      "minLength": 8,
      "maxLength": 360
    },
    "emotion": {
      "type": "string",
      "enum": [
        "urgent",
        "analytical",
        "shocking",
        "mysterious",
        "serious",
        "optimistic",
        "conflict",
        "warning"
      ]
    },
    "stakes": {
      "type": "string",
      "maxLength": 280
    },
    "curiosity_gap": {
      "type": "string",
      "maxLength": 220
    },
    "key_numbers": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/key_number"
      }
    },
    "approved_thumbnail_text": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 42
      }
    },
    "forbidden_thumbnail_text": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 80
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "person_images",
        "logos",
        "background_images",
        "maps",
        "screenshots"
      ],
      "properties": {
        "person_images": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/asset"
          }
        },
        "logos": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/asset"
          }
        },
        "background_images": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/asset"
          }
        },
        "maps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/asset"
          }
        },
        "screenshots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/asset"
          }
        },
        "documents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/asset"
          }
        },
        "objects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/asset"
          }
        }
      }
    },
    "render_preferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "candidate_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8,
          "default": 5
        },
        "preferred_templates": {
          "type": "array",
          "maxItems": 6,
          "items": {
            "type": "string",
            "enum": [
              "authority_warning",
              "clean_market_surge",
              "global_ai_faceoff",
              "sovereign_ai_stack",
              "money_deal_bomb",
              "map_crisis_marker",
              "factory_boom",
              "logo_collision",
              "device_shock",
              "agent_swarm",
              "document_exposed",
              "infrastructure_race",
              "inside_the_deal"
            ]
          }
        },
        "avoid_templates": {
          "type": "array",
          "maxItems": 6,
          "items": {
            "type": "string"
          }
        },
        "brand_intensity": {
          "type": "string",
          "enum": [
            "subtle",
            "standard",
            "strong"
          ],
          "default": "standard"
        },
        "allow_symbolic_generated_background": {
          "type": "boolean",
          "default": true
        },
        "allow_real_person_generation": {
          "type": "boolean",
          "const": false,
          "default": false
        },
        "output_dir": {
          "type": "string"
        }
      }
    },
    "compliance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "must_use_only_approved_assets": {
          "type": "boolean",
          "default": false
        },
        "requires_human_review": {
          "type": "boolean",
          "default": true
        },
        "notes": {
          "type": "string",
          "maxLength": 500
        }
      }
    }
  },
  "$defs": {
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "person",
            "company",
            "country",
            "object",
            "product",
            "model",
            "place",
            "organization",
            "event"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "role": {
          "type": "string",
          "maxLength": 120
        },
        "importance": {
          "type": "string",
          "enum": [
            "primary",
            "secondary",
            "context"
          ],
          "default": "primary"
        },
        "visual_priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "default": 3
        },
        "desired_emotion": {
          "type": "string",
          "enum": [
            "neutral",
            "confident",
            "concerned",
            "serious",
            "urgent",
            "optimistic",
            "competitive"
          ]
        }
      }
    },
    "key_number": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "value"
      ],
      "properties": {
        "label": {
          "type": "string",
          "maxLength": 80
        },
        "value": {
          "type": "string",
          "maxLength": 40
        },
        "unit": {
          "type": "string",
          "maxLength": 40
        },
        "source": {
          "type": "string",
          "maxLength": 240
        },
        "confidence": {
          "type": "string",
          "enum": [
            "confirmed",
            "reported",
            "estimated"
          ],
          "default": "reported"
        }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path_or_url",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9._-]+$"
        },
        "path_or_url": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "maxLength": 80
        },
        "type": {
          "type": "string",
          "enum": [
            "person_image",
            "logo",
            "background_image",
            "map",
            "screenshot",
            "document",
            "object",
            "icon",
            "generated_background",
            "hero_composite",
            "foreground_composite"
          ]
        },
        "subject_name": {
          "type": "string",
          "maxLength": 120
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "license": {
          "type": "string",
          "maxLength": 160
        },
        "attribution": {
          "type": "string",
          "maxLength": 240
        },
        "usage_status": {
          "type": "string",
          "enum": [
            "approved",
            "needs_review",
            "internal_only",
            "do_not_use"
          ],
          "default": "needs_review"
        },
        "focal_point": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "x": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "y": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "notes": {
          "type": "string",
          "maxLength": 400
        }
      }
    }
  }
}
