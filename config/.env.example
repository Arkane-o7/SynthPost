# SynthPost local pipeline settings

# Avatar-Engine
SYNTHPOST_AVATAR_ENGINE_DIR=avatar-engine
SYNTHPOST_AVATAR_TEST_MODE=0
SYNTHPOST_AVATAR_TTS_PROBE=0
SYNTHPOST_ALLOW_PLACEHOLDER_ANCHOR=0
SYNTHPOST_WORDS_PER_MINUTE=145
SYNTHPOST_AVATAR_VOICE_ID=af_heart
SYNTHPOST_AVATAR_VOICE_SPEED=1.0

# Content writing. Milestone 2 does not require this.
SYNTHPOST_LLM_PROVIDER=ollama
SYNTHPOST_OLLAMA_URL=http://localhost:11434/api/generate
SYNTHPOST_OLLAMA_MODEL=llama3.1

# News collection. Milestone 2 does not require this.
SYNTHPOST_RSS_FEEDS=https://www.theverge.com/rss/index.xml,https://www.firstpost.com/commonfeeds/v1/mfp/rss/world.xml

# News visuals. Local library is searched first, then open/optional providers.
SYNTHPOST_VISUAL_LIBRARY=
SYNTHPOST_TRUST_LOCAL_VISUAL_LIBRARY=1
# Leave SYNTHPOST_VISUAL_SEGMENTS empty for duration-based pacing.
SYNTHPOST_VISUAL_SEGMENTS=
SYNTHPOST_VISUAL_SECONDS_PER_BEAT=7.5
SYNTHPOST_VISUAL_MIN_SEGMENTS=4
SYNTHPOST_VISUAL_MAX_SEGMENTS=14
SYNTHPOST_TRUST_MANIFEST_MEDIA=1
SYNTHPOST_TRUST_SOURCE_PAGE_MEDIA=0
SYNTHPOST_DISABLE_SOURCE_PAGE_MEDIA=0
SYNTHPOST_ENABLE_CONTEXT_GRAPHICS=0
SYNTHPOST_ALLOW_YELLOW_VISUALS=0
SYNTHPOST_ALLOW_RISKY_SOCIAL=0
SYNTHPOST_DISABLE_WEB_VISUALS=0
SYNTHPOST_INCLUDE_VISUAL_LEADS=0
SYNTHPOST_VISUAL_DOWNLOAD_MAX_BYTES=104857600

# Premium-free source drop folders. Each folder may contain media files plus
# optional sidecars such as clip.mp4.json with rights/attribution metadata.
SYNTHPOST_PB_SHABD_MEDIA_DIR=
SYNTHPOST_PIB_MEDIA_DIR=
SYNTHPOST_ISRO_MEDIA_DIR=
SYNTHPOST_PM_INDIA_MEDIA_DIR=
SYNTHPOST_INDIA_MINISTRY_MEDIA_DIR=
SYNTHPOST_MEA_INDIA_MEDIA_DIR=
SYNTHPOST_NASA_MEDIA_DIR=
SYNTHPOST_DVIDS_MEDIA_DIR=
SYNTHPOST_EU_AV_MEDIA_DIR=
SYNTHPOST_WHITE_HOUSE_MEDIA_DIR=
SYNTHPOST_STATE_DEPARTMENT_MEDIA_DIR=
SYNTHPOST_NOAA_MEDIA_DIR=
SYNTHPOST_USGS_MEDIA_DIR=
SYNTHPOST_COPERNICUS_MEDIA_DIR=
SYNTHPOST_LOC_MEDIA_DIR=
SYNTHPOST_NARA_MEDIA_DIR=
SYNTHPOST_INTERNET_ARCHIVE_MEDIA_DIR=
SYNTHPOST_NATURAL_EARTH_MEDIA_DIR=
SYNTHPOST_OFFICIAL_SCREENSHOT_DIR=
SYNTHPOST_DOCUMENT_SCREENSHOT_DIR=
SYNTHPOST_COURT_DOCUMENT_DIR=
SYNTHPOST_LEGISLATURE_MEDIA_DIR=
SYNTHPOST_COMPANY_PRESS_KIT_DIR=
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Compositor / assembly
SYNTHPOST_REMOTION_DIR=compositor/remotion_renderer
SYNTHPOST_FFMPEG=ffmpeg
SYNTHPOST_RENDER_CODEC=h264
SYNTHPOST_RENDER_PREVIEW_FRAME=24
