# SynthPost local pipeline settings

# Avatar-Engine
SYNTHPOST_AVATAR_ENGINE_DIR=avatar-engine
SYNTHPOST_AVATAR_TEST_MODE=0
SYNTHPOST_AVATAR_TTS_PROBE=0
SYNTHPOST_ALLOW_PLACEHOLDER_ANCHOR=0
SYNTHPOST_WORDS_PER_MINUTE=145
SYNTHPOST_AVATAR_VOICE_ID=af_heart
SYNTHPOST_AVATAR_VOICE_SPEED=1.0

# Content writing. Milestone 2 does not require this.
SYNTHPOST_LLM_PROVIDER=groq
SYNTHPOST_LLM_REQUEST_TIMEOUT_SECONDS=45
GROQ_API_KEY=
SYNTHPOST_GROQ_MODEL=openai/gpt-oss-120b
SYNTHPOST_GROQ_TEMPERATURE=0.2
GEMINI_API_KEY=
SYNTHPOST_GEMINI_MODEL=gemini-3.5-flash
SYNTHPOST_GEMINI_TEMPERATURE=0.2
# Optional explicit hosted-only failover: Groq primary, Gemini secondary.
# SYNTHPOST_LLM_PROVIDER=hosted_fallback
# Provider validation/retry hardening. Debug outputs are disabled by default
# because they can contain raw LLM output and should not be committed.
SYNTHPOST_LLM_MAX_RETRIES=2
SYNTHPOST_SAVE_LLM_DEBUG=0
# short = 60-90s, standard = 3-5m, longform = 5-15m.
SYNTHPOST_SCRIPT_DURATION_MODE=short
# Optional explicit target, clamped to the selected duration mode.
SYNTHPOST_SCRIPT_TARGET_SECONDS=
# mock is reserved for deterministic tests/smoke demos, never production scripts.
SYNTHPOST_NEWS_POINTS_PROVIDER=mock

# News collection. Milestone 2 does not require this.
# Leave SYNTHPOST_RSS_FEEDS empty to use the built-in category feed registry.
# Custom feeds may be comma-separated URLs, or category|source name|url|tier.
SYNTHPOST_RSS_FEEDS=
SYNTHPOST_RSS_CATEGORIES=
SYNTHPOST_RSS_CACHE=1
SYNTHPOST_RSS_CACHE_TTL_SECONDS=1800

# News visuals. Local library is searched first, then open/optional providers.
SYNTHPOST_VISUAL_LIBRARY=
SYNTHPOST_TRUST_LOCAL_VISUAL_LIBRARY=1
# Leave SYNTHPOST_VISUAL_SEGMENTS empty for duration-based pacing.
SYNTHPOST_VISUAL_SEGMENTS=
SYNTHPOST_VISUAL_SECONDS_PER_BEAT=7.5
SYNTHPOST_VISUAL_MIN_SEGMENTS=4
SYNTHPOST_VISUAL_MAX_SEGMENTS=14
SYNTHPOST_TRUST_MANIFEST_MEDIA=1
SYNTHPOST_TRUST_SOURCE_PAGE_MEDIA=0
SYNTHPOST_DISABLE_SOURCE_PAGE_MEDIA=0
# auto generates story-specific source/context cards when real event media is sparse.
SYNTHPOST_ENABLE_CONTEXT_GRAPHICS=auto
SYNTHPOST_ALLOW_YELLOW_VISUALS=0
SYNTHPOST_ALLOW_RISKY_SOCIAL=0
SYNTHPOST_DISABLE_WEB_VISUALS=0
SYNTHPOST_INCLUDE_VISUAL_LEADS=1
SYNTHPOST_VISUAL_DOWNLOAD_MAX_BYTES=104857600

# SearXNG powers related-news research plus image/video discovery. JSON output
# must be enabled in the instance's search.formats setting.
SYNTHPOST_SEARXNG_URL=http://127.0.0.1:8888
SYNTHPOST_SEARXNG_LANGUAGE=en
SYNTHPOST_SEARXNG_SAFESEARCH=1
SYNTHPOST_SEARXNG_TIMEOUT=20
SYNTHPOST_SEARXNG_RETRIES=2
SYNTHPOST_SEARXNG_NEWS_RESULTS=12
SYNTHPOST_SEARXNG_NEWS_TIME_RANGE=month
SYNTHPOST_RESEARCH_MAX_DOCUMENTS=6
SYNTHPOST_RESEARCH_CLAIMS_PER_DOCUMENT=8
SYNTHPOST_AI_VISUAL_QUERY_PLANNING=1
# Hard cap on actual SearXNG image/video search requests per visual job.
SYNTHPOST_SEARXNG_VISUAL_MAX_QUERIES=12
SYNTHPOST_SEARXNG_IMAGE_RESULTS_PER_QUERY=3
SYNTHPOST_SEARXNG_VIDEO_RESULTS_PER_QUERY=2
# Download the strongest matching video results with yt-dlp so they can enter
# analysis and approval; clips that fail acquisition remain research leads.
SYNTHPOST_SEARXNG_DOWNLOAD_VIDEOS=1
SYNTHPOST_SEARXNG_VIDEO_DOWNLOAD_LIMIT=6
SYNTHPOST_SEARXNG_VIDEO_CLIP_SECONDS=45
SYNTHPOST_VISUAL_ENFORCE_BROADCAST_FIT=1
SYNTHPOST_VISUAL_MIN_WIDTH=1280
SYNTHPOST_VISUAL_MIN_HEIGHT=720
SYNTHPOST_VISUAL_ASPECT_TOLERANCE=0.20
SYNTHPOST_VISUAL_IMAGE_ASPECT_TOLERANCE=0.30
SYNTHPOST_TESSERACT=tesseract
SYNTHPOST_VIDEO_APPROVED_CHANNEL_IDS=
SYNTHPOST_VIDEO_APPROVED_SOURCE_NAMES=
SYNTHPOST_VIDEO_BLOCKED_SOURCE_NAMES=
SYNTHPOST_SEARXNG_VIDEO_MAX_DURATION=900
SYNTHPOST_SEARXNG_VIDEO_TIMEOUT=300
SYNTHPOST_YT_DLP=yt-dlp

# Premium-free source drop folders. Each folder may contain media files plus
# optional sidecars such as clip.mp4.json with rights/attribution metadata.
SYNTHPOST_PB_SHABD_MEDIA_DIR=
SYNTHPOST_PIB_MEDIA_DIR=
SYNTHPOST_ISRO_MEDIA_DIR=
SYNTHPOST_PM_INDIA_MEDIA_DIR=
SYNTHPOST_INDIA_MINISTRY_MEDIA_DIR=
SYNTHPOST_MEA_INDIA_MEDIA_DIR=
SYNTHPOST_NASA_MEDIA_DIR=
SYNTHPOST_DVIDS_MEDIA_DIR=
SYNTHPOST_EU_AV_MEDIA_DIR=
SYNTHPOST_WHITE_HOUSE_MEDIA_DIR=
SYNTHPOST_STATE_DEPARTMENT_MEDIA_DIR=
SYNTHPOST_NOAA_MEDIA_DIR=
SYNTHPOST_USGS_MEDIA_DIR=
SYNTHPOST_COPERNICUS_MEDIA_DIR=
SYNTHPOST_LOC_MEDIA_DIR=
SYNTHPOST_NARA_MEDIA_DIR=
SYNTHPOST_INTERNET_ARCHIVE_MEDIA_DIR=
SYNTHPOST_NATURAL_EARTH_MEDIA_DIR=
SYNTHPOST_OFFICIAL_SCREENSHOT_DIR=
SYNTHPOST_DOCUMENT_SCREENSHOT_DIR=
SYNTHPOST_COURT_DOCUMENT_DIR=
SYNTHPOST_LEGISLATURE_MEDIA_DIR=
SYNTHPOST_COMPANY_PRESS_KIT_DIR=
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Compositor / assembly
SYNTHPOST_REMOTION_DIR=compositor/remotion_renderer
SYNTHPOST_FFMPEG=ffmpeg
# preview = 720p/15fps, production = 1080p/24fps, final_master = 4K/30fps.
SYNTHPOST_RENDER_PROFILE=production
SYNTHPOST_RENDER_CODEC=h264
SYNTHPOST_RENDER_PREVIEW_FRAME=24
