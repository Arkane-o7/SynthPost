  "minimum_eligibility_matches": 3,
  "reject_patterns": {
    "shopping": ["best ", "buying guide", "deal", "discount", "coupon", "gift guide", "prime day", "black friday", "under $", "under ₹"],
    "product_list": ["top 10", "top 15", "top 20", "best of", "products of", "must-have"],
    "hiring": ["is hiring", "we're hiring", "job opening", "apply now", "vacancy"],
    "celebrity": ["celebrity", "bollywood", "actor", "actress", "dating", "wedding", "box office", "red carpet"],
    "routine_politics": ["slams", "hits out", "demands apology", "reacts to remarks", "party spokesperson", "campaign rally"],
    "routine_announcement": ["press release", "sponsored", "announces partnership", "expanded partnership", "partnership with", "signs mou", "to train", "training programme", "certification program", "launches campaign", "hosts event", "webinar", "meetup", "conference registration"],
    "empty_breaking_churn": ["breaking:", "live:", "latest updates", "minute-by-minute"]
  },
  "research_lens": [
    "What system is changing?",
    "Who are the stakeholders and who bears the consequences?",
    "What evidence supports the central development?",
    "What are the trade-offs?",
    "Where are the execution gaps, bottlenecks or unknowns?",
    "What is specifically relevant to India?",
    "What should viewers watch next?"
  ],
  "headline_rules": {
    "episode_words": [8, 16],
    "cue_words": [4, 10],
    "episode_max_chars": 110,
    "lower_third_max_chars": 80,
    "chyron_max_chars": 64,
    "prefer": ["Named actors", "Concrete developments", "Supported consequences", "Active voice", "Sentence case"],
    "avoid": ["What you need to know", "A closer look", "What this means", "Faces setback", "Raises questions", "Candidate issues", "The future of", "Unnecessary colons", "Sensational adjectives"]
  },
  "visual_preferences": [
    "Maps and geographic context",
    "Diagrams that explain systems and flows",
    "Data visualizations grounded in sourced numbers",
    "Infrastructure and industrial processes",
    "Primary documents and records",
    "Authentic event footage from official or primary sources",
    "Product demonstrations and real interfaces",
    "People only when they are central actors rather than generic decoration"
  ],
  "show_formats": {
    "signal": {
      "label": "SynthPost Signal",
      "duration_minutes": [3, 5],
      "structure": ["What happened", "Why now", "Who is affected", "What happens next"],
      "narration": ["Fast, presenter-led and decisive", "Prefer 9-12 words per sentence", "Open on the development, not background", "Use at most two rhetorical questions in the entire script", "Give one number and immediately explain why it matters"]
    },
    "explained": {
      "label": "SynthPost Explained",
      "duration_minutes": [8, 12],
      "structure": ["Cold open", "Verified development", "Context", "How the system works", "Consequences", "Uncertainty", "What to watch"],
      "narration": ["Conversational but information-dense", "Prefer 11-15 words per sentence", "Define technical terms in plain language at first use", "Alternate evidence with interpretation", "Use clean pivots to move from event to system to consequence"]
    },
    "deep_dive": {
      "label": "SynthPost Deep Dive",
      "duration_minutes": [15, 25],
      "structure": ["Central question", "System map", "Evidence", "Stakeholders", "Trade-offs", "Execution gaps", "Scenarios", "What to watch"],
      "narration": ["Investigative, patient and thesis-driven", "Prefer 13-18 words per sentence with short emphasis lines", "Build causal chains instead of chronological lists", "Test the strongest claim against counter-evidence", "Distinguish the base case, competing scenarios and unknowns"]
    },
    "india_builds": {
      "label": "India Builds",
      "duration_minutes": [30, 120],
      "structure": ["What is being built", "The physical and institutional system", "Why India needs it", "History and current capacity", "Money and stakeholders", "Execution bottlenecks", "Comparable global systems", "What success would change"],
      "narration": ["Documentary, physical and systems-oriented", "Prefer 12-16 words per sentence", "Describe how infrastructure, institutions and supply chains work", "Translate capacity, cost and timelines into human scale", "Balance national ambition with execution evidence", "Use chapters and forward references to sustain long-form attention"]
    }
  }
}
