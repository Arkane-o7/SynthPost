    "india_impact_signals": ["india", "indian", "rbi", "isro", "upi", "aadhaar", "meity", "sebi", "nasscom", "reliance", "jio", "tata", "infosys", "tcs", "wipro", "bengaluru", "hyderabad", "chennai", "mumbai", "delhi"],
