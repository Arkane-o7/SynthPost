  "eligibility_criteria": [
    {"id": "system_change", "label": "Changes how a consequential system works"},
    {"id": "meaningful_impact", "label": "Affects a meaningful number of people"},
    {"id": "india_connection", "label": "Has an India connection"},
    {"id": "tradeoff_or_uncertainty", "label": "Contains a conflict, trade-off or uncertainty"},
    {"id": "visual_explainability", "label": "Can be explained visually"},
    {"id": "credible_evidence", "label": "Has credible, inspectable evidence"},
    {"id": "beyond_announcement", "label": "Has implications beyond the original announcement"},
    {"id": "durable_value", "label": "Will still be useful several days after publication"}
