{
  "charter_id": "synthpost",
  "version": "1.2.1",
  "effective_date": "2026-07-13",
  "editorial_promise": "SynthPost explains the systems shaping India's future—and India's place in the world.",
  "positioning": "A premium, India-first visual explainer publication about technology, science, infrastructure, business, internet culture, policy and power.",
  "lens": "Explain where technology meets people, institutions, money, internet culture and power.",
  "editorial_influence": {
    "verge_editorial_model": 0.5,
    "aim_subject_focus": 0.3,
    "firstpost_video_presentation": 0.2
  },
  "audience": {
    "primary": [
      "Indian professionals aged 20–40",
      "Developers, founders, analysts and students",
      "Globally curious viewers who follow technology and public policy",
      "Viewers who want more depth than a short and less time commitment than a podcast"
    ],
    "secondary": [
      "International viewers interested in India",
      "The Indian diaspora",
      "Business and policy audiences"
    ]
  },
  "tone": [
    "Intelligent without sounding academic",
    "Confident without manufacturing certainty",
    "Curious rather than cynical",
    "Visually sophisticated",
    "India-rooted but not nationalistic",
    "Analytical without becoming partisan",
    "Comfortable stating what remains unknown"
  ],
  "narration_principles": [
    "Open with a concrete scene, consequential fact or contradiction within the first 60 words",
    "Write for the ear with mostly short and medium sentences, then use an occasional longer sentence to connect systems",
    "Translate every important number into scale, consequence or comparison",
    "Place India inside the relevant global system without boosterism or imported framing",
    "Use direct address only when it clarifies the viewer's stake",
    "Use rhetorical questions selectively and answer them with evidence",
    "Move with clear spoken pivots such as but, now and so without turning them into verbal tics",
    "Follow confident claims with attribution, evidence or an explicit boundary on what is known",
    "End sections by advancing the argument rather than recapping the previous paragraph"
  ],
  "narration_avoid": [
    "Like-share-subscribe interruptions",
    "Breathless breaking-news language",
    "Triumphalism, nationalism or corporate promotion",
    "Academic throat-clearing and unexplained jargon",
    "Strings of statistics without interpretation",
    "Manufactured conflict, certainty or suspense",
    "Repeated rhetorical questions",
    "Generic scene-setting that delays the central development"
  ],
  "priority_verticals": {
    "technology": ["technology", "digital", "platform", "internet", "cybersecurity", "telecom", "software", "computing"],
    "artificial_intelligence": ["artificial intelligence", "ai", "machine learning", "model", "agent", "data centre", "data center"],
