{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synthpost.local/schemas/story_candidate.schema.json",
  "title": "SynthPost Story Candidate File",
  "type": "object",
  "required": ["episode_id", "generated_at", "candidate_count", "candidates"],
  "properties": {
    "episode_id": { "type": "string" },
    "generated_at": { "type": "string" },
    "candidate_count": { "type": "number" },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "candidate_id",
          "cluster_id",
          "headline",
          "normalized_headline",
          "source",
          "source_name",
          "source_url",
          "source_provider",
          "source_type",
          "source_category",
          "feed_url",
          "source_domain",
          "published_at",
          "category",
          "summary",
          "facts",
          "entities",
          "key_entities",
          "source_reliability_tier",
          "source_ids",
          "claim_ids",
          "why_it_matters",
          "why_it_could_perform_well",
          "possible_synthpost_angle",
          "possible_thumbnail_hook",
          "possible_title_ideas",
          "visual_opportunities",
          "risks_or_reasons_to_avoid",
          "selection_status",
          "selection_reason",
          "rejection_reason",
          "rejection_reasons",
          "score_reasons",
          "dedupe_status",
          "dedupe_reasons",
          "dedupe_merged_candidate_ids",
          "dedupe_merged_source_urls",
          "importance_score",
          "viral_potential_score",
          "visual_potential_score",
          "freshness_score",
          "source_reliability_score",
          "synthpost_fit_score",
          "controversy_or_tension_score",
          "explainability_score",
          "final_editorial_score"
        ],
        "properties": {
          "candidate_id": { "type": "string" },
          "cluster_id": { "type": "string" },
          "headline": { "type": "string" },
          "normalized_headline": { "type": "string" },
          "source": { "type": "string" },
          "source_name": { "type": "string" },
          "source_url": { "type": "string" },
          "source_provider": { "type": "string" },
          "source_type": { "type": "string" },
          "source_category": { "type": "string" },
          "feed_url": { "type": "string" },
          "source_domain": { "type": "string" },
          "published_at": { "type": "string" },
          "category": { "type": "string" },
          "summary": { "type": "string" },
          "facts": { "type": "array", "items": { "type": "string" } },
          "entities": { "type": "array", "items": { "type": "string" } },
          "key_entities": { "type": "array", "items": { "type": "string" } },
          "source_reliability_tier": { "type": "string" },
          "source_ids": { "type": "array", "items": { "type": "string" } },
          "claim_ids": { "type": "array", "items": { "type": "string" } },
          "why_it_matters": { "type": "string" },
          "why_it_could_perform_well": { "type": "string" },
          "possible_synthpost_angle": { "type": "string" },
          "possible_thumbnail_hook": { "type": "string" },
          "possible_title_ideas": { "type": "array", "items": { "type": "string" } },
          "visual_opportunities": { "type": "array", "items": { "type": "string" } },
          "risks_or_reasons_to_avoid": { "type": "array", "items": { "type": "string" } },
          "selection_status": { "type": "string", "enum": ["selected", "rejected", "candidate"] },
          "selection_reason": { "type": "string" },
          "rejection_reason": { "type": "string" },
          "rejection_reasons": { "type": "array", "items": { "type": "string" } },
          "score_reasons": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "dedupe_status": { "type": "string" },
          "dedupe_reasons": { "type": "array", "items": { "type": "string" } },
          "dedupe_merged_candidate_ids": { "type": "array", "items": { "type": "string" } },
          "dedupe_merged_source_urls": { "type": "array", "items": { "type": "string" } },
          "importance_score": { "type": "number" },
          "viral_potential_score": { "type": "number" },
          "visual_potential_score": { "type": "number" },
          "freshness_score": { "type": "number" },
          "source_reliability_score": { "type": "number" },
          "synthpost_fit_score": { "type": "number" },
          "controversy_or_tension_score": { "type": "number" },
          "explainability_score": { "type": "number" },
          "final_editorial_score": { "type": "number" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
