# Copy this file to .env and fill in local secrets/config.
# Never commit .env or .env.local.

SYNTHPOST_LLM_PROVIDER=gemini
GEMINI_API_KEY=replace_with_your_gemini_api_key
SYNTHPOST_GEMINI_MODEL=gemini-3.5-flash
SYNTHPOST_GEMINI_TEMPERATURE=0.2



# Optional Ollama fallback/local config
# SYNTHPOST_LLM_PROVIDER=ollama
# SYNTHPOST_OLLAMA_BASE_URL=http://127.0.0.1:11434
# SYNTHPOST_OLLAMA_MODEL=gemma4:26b
# SYNTHPOST_OLLAMA_FALLBACK_MODELS=gemma4:e2b-mlx
# SYNTHPOST_OLLAMA_TIMEOUT=240
# SYNTHPOST_OLLAMA_TEMPERATURE=0.2

# Avatar render timeout padding for long local renders
AVATAR_ENGINE_BROWSER_TIMEOUT_PADDING_S=900

# SearXNG news research and visual discovery. Start the bundled local instance
# with `make searxng-up`, or point this at an existing private instance whose
# settings.yml enables JSON in search.formats.
SYNTHPOST_SEARXNG_URL=http://127.0.0.1:8888
SYNTHPOST_SEARXNG_LANGUAGE=en
SYNTHPOST_SEARXNG_SAFESEARCH=1
SYNTHPOST_SEARXNG_NEWS_RESULTS=12
SYNTHPOST_RESEARCH_MAX_DOCUMENTS=6
SYNTHPOST_AI_VISUAL_QUERY_PLANNING=1
SYNTHPOST_AI_VISUAL_CLEANLINESS=1
# Hard cap on actual SearXNG image/video search requests per visual job.
# 12 supports one image + one video query for a typical six-section story.
SYNTHPOST_SEARXNG_VISUAL_MAX_QUERIES=12
SYNTHPOST_SEARXNG_IMAGE_RESULTS_PER_QUERY=3
SYNTHPOST_SEARXNG_VIDEO_RESULTS_PER_QUERY=2
SYNTHPOST_INCLUDE_VISUAL_LEADS=1
# Video results are research leads by default. Enabling this invokes yt-dlp;
# downloaded clips still require manual rights review before approval.
SYNTHPOST_SEARXNG_DOWNLOAD_VIDEOS=0
SYNTHPOST_SEARXNG_VIDEO_DOWNLOAD_LIMIT=2
SYNTHPOST_SEARXNG_VIDEO_CLIP_SECONDS=45
SYNTHPOST_VISUAL_ENFORCE_BROADCAST_FIT=1
SYNTHPOST_VISUAL_MIN_WIDTH=1920
SYNTHPOST_VISUAL_MIN_HEIGHT=1080
SYNTHPOST_VISUAL_ASPECT_TOLERANCE=0.20
SYNTHPOST_TESSERACT=tesseract
# Comma-separated exact channel IDs or source-name fragments maintained by the editor.
SYNTHPOST_VIDEO_APPROVED_CHANNEL_IDS=
SYNTHPOST_VIDEO_APPROVED_SOURCE_NAMES=
SYNTHPOST_VIDEO_BLOCKED_SOURCE_NAMES=
