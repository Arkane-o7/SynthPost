# SynthPost local configuration. Copy to .env; never commit real credentials.
# Defaults shown here match pipeline/config.py. See docs/CONFIGURATION.md.

# Server and Studio
SYNTHPOST_SERVER_HOST=127.0.0.1
SYNTHPOST_SERVER_PORT=8765
SYNTHPOST_STUDIO_HOST=127.0.0.1
SYNTHPOST_STUDIO_PORT=5173
SYNTHPOST_LOG_LEVEL=INFO
SYNTHPOST_LOG_FORMAT=human

# Storage
SYNTHPOST_DB_PATH=.synthpost/synthpost.sqlite3

# Structured LLM providers (mock is only for tests and smoke demos)
SYNTHPOST_LLM_PROVIDER=groq
SYNTHPOST_LLM_REQUEST_TIMEOUT_SECONDS=45
SYNTHPOST_LLM_MAX_RETRIES=2
SYNTHPOST_SAVE_LLM_DEBUG=0
GROQ_API_KEY=replace_with_your_groq_api_key
SYNTHPOST_GROQ_MODEL=openai/gpt-oss-120b
SYNTHPOST_GROQ_TEMPERATURE=0.2
SYNTHPOST_GROQ_MAX_COMPLETION_TOKENS=2300
GEMINI_API_KEY=replace_with_your_gemini_api_key
SYNTHPOST_GEMINI_MODEL=gemini-3.5-flash
SYNTHPOST_GEMINI_TEMPERATURE=0.2

# Discovery, research, and assignment desk
SYNTHPOST_AI_ASSIGNMENT_DESK=1
SYNTHPOST_ASSIGNMENT_DESK_AI_LIMIT=12
SYNTHPOST_DISCOVERY_MAX_AGE_HOURS=240
SYNTHPOST_DISCOVERY_WORKERS=6
SYNTHPOST_RESEARCH_MAX_DOCUMENTS=6
SYNTHPOST_RESEARCH_CLAIMS_PER_DOCUMENT=8
SYNTHPOST_RESEARCH_MIN_RELEVANCE=0.15
SYNTHPOST_RESEARCH_RSS_SOURCE_LIMIT=10

# Private/local SearXNG
SYNTHPOST_SEARXNG_URL=http://127.0.0.1:8888
SYNTHPOST_SEARXNG_API_KEY=
SYNTHPOST_SEARXNG_LANGUAGE=en
SYNTHPOST_SEARXNG_SAFESEARCH=1
SYNTHPOST_SEARXNG_TIMEOUT=20
SYNTHPOST_SEARXNG_RETRIES=2
SYNTHPOST_SEARXNG_NEWS_RESULTS=12
SYNTHPOST_SEARXNG_NEWS_TIME_RANGE=month
SYNTHPOST_SEARXNG_SOCKET_TIMEOUT=15

# Visual discovery, acquisition, and review
SYNTHPOST_AI_VISUAL_QUERY_PLANNING=1
SYNTHPOST_AI_VISUAL_CLEANLINESS=1
SYNTHPOST_INCLUDE_VISUAL_LEADS=1
SYNTHPOST_DISABLE_WEB_VISUALS=0
SYNTHPOST_GENERATE_FALLBACK_VISUALS=1
SYNTHPOST_SEARXNG_VISUAL_MAX_QUERIES=12
SYNTHPOST_SEARXNG_IMAGE_RESULTS_PER_QUERY=3
SYNTHPOST_SEARXNG_VIDEO_RESULTS_PER_QUERY=2
SYNTHPOST_SEARXNG_DOWNLOAD_VIDEOS=1
SYNTHPOST_SEARXNG_VIDEO_DOWNLOAD_LIMIT=6
SYNTHPOST_SEARXNG_VIDEO_CLIP_SECONDS=45
SYNTHPOST_SEARXNG_VIDEO_MAX_DURATION=900
SYNTHPOST_SEARXNG_VIDEO_TIMEOUT=300
SYNTHPOST_VISUAL_DOWNLOAD_TIMEOUT=30
SYNTHPOST_VISUAL_DOWNLOAD_MAX_BYTES=104857600
SYNTHPOST_VISUAL_ENFORCE_BROADCAST_FIT=1
SYNTHPOST_VISUAL_MIN_WIDTH=1280
SYNTHPOST_VISUAL_MIN_HEIGHT=720
SYNTHPOST_VISUAL_ASPECT_TOLERANCE=0.20
SYNTHPOST_VISUAL_IMAGE_ASPECT_TOLERANCE=0.30
SYNTHPOST_YT_DLP=yt-dlp
SYNTHPOST_TESSERACT=tesseract
SYNTHPOST_VIDEO_APPROVED_CHANNEL_IDS=
SYNTHPOST_VIDEO_APPROVED_SOURCE_NAMES=
SYNTHPOST_VIDEO_BLOCKED_SOURCE_NAMES=

# Script and timeline policy
SYNTHPOST_WORDS_PER_MINUTE=145
SYNTHPOST_STRICT_DURATION=1
# Experimental: source clips do not have verified edit timestamps by default.
SYNTHPOST_EXPERIMENTAL_SOURCE_AUDIO=0

# Avatar integration
SYNTHPOST_AVATAR_ENGINE_PATH=avatar-engine
# Deprecated alias, supported for compatibility: SYNTHPOST_AVATAR_ENGINE_DIR
SYNTHPOST_AVATAR_PYTHON=
SYNTHPOST_AVATAR_RENDERER=rocketbox
SYNTHPOST_AVATAR_ASSET_PATH=assets/avatars/synthpost_anchor_v1/anchor.glb
SYNTHPOST_AVATAR_META_PATH=assets/avatars/synthpost_anchor_v1/avatar.json
SYNTHPOST_AVATAR_STYLE=professional_news_anchor
SYNTHPOST_AVATAR_BODY_FORM=F
SYNTHPOST_AVATAR_RENDER_BACKGROUND=charcoal
SYNTHPOST_AVATAR_VOICE_ID=af_heart
SYNTHPOST_AVATAR_VOICE_SPEED=1.10
SYNTHPOST_NARRATION_BEAT_PAUSE_MS=80
SYNTHPOST_NARRATION_SECTION_PAUSE_MS=220
SYNTHPOST_AVATAR_LANG_CODE=a
SYNTHPOST_AVATAR_DISTANCE_MULTIPLIER=0.86
SYNTHPOST_AVATAR_TARGET_HEIGHT_FACTOR=0.52
SYNTHPOST_AVATAR_HEIGHT_FACTOR=0.86
SYNTHPOST_AVATAR_ROTATION_Y_DEGREES=0
SYNTHPOST_AVATAR_TTS_PROBE=0
SYNTHPOST_ALLOW_PLACEHOLDER_ANCHOR=0
AVATAR_ENGINE_RENDERER=rocketbox
AVATAR_ENGINE_ALLOW_RENDERER_FALLBACK=0
AVATAR_ENGINE_ALLOW_2D_FACE_FALLBACK=0
AVATAR_ENGINE_BROWSER_TIMEOUT_PADDING_S=900
AVATAR_ENGINE_ESTIMATED_BYTES_PER_FRAME=1250000
AVATAR_ENGINE_MIN_RENDER_FREE_BYTES=5368709120
AVATAR_ENGINE_KEEP_FAILED_TEMP=0

# Remotion, FFmpeg, and rendering
SYNTHPOST_REMOTION_DIR=compositor/remotion_renderer
# Per-render Remotion frame concurrency; total is multiplied by active renders.
SYNTHPOST_REMOTION_CONCURRENCY=4
SYNTHPOST_FFMPEG=ffmpeg
SYNTHPOST_RENDER_PROFILE=production
SYNTHPOST_RENDER_CODEC=h264
SYNTHPOST_RENDER_PREVIEW_FRAME=24

# Queue lanes, parallel process capacity, and retry policy
# Raise these for a high-core-count machine. Each render worker may launch
# Chromium/Remotion, Avatar Engine, Blender, or FFmpeg subprocesses.
SYNTHPOST_EDITORIAL_WORKERS=3
SYNTHPOST_MEDIA_WORKERS=3
SYNTHPOST_RENDER_WORKERS=3
SYNTHPOST_EDITORIAL_JOB_MAX_ATTEMPTS=3
SYNTHPOST_MEDIA_JOB_MAX_ATTEMPTS=3
SYNTHPOST_RENDER_JOB_MAX_ATTEMPTS=2
SYNTHPOST_JOB_RETRY_BASE_SECONDS=15
SYNTHPOST_JOB_RETRY_MAX_SECONDS=900
SYNTHPOST_JOB_HEARTBEAT_SECONDS=5
