# Avatar GLB/VRM assets and raw CC/Reallusion export dumps are large.
# Keep small runtime metadata (for example assets/avatars/*/avatar.json) in Git,
# but store binary avatars/textures externally or via LFS.
assets/avatars/**/*.glb
assets/avatars/**/*.vrm
assets/avatars/**/*.fbx
assets/avatars/**/textures/
assets/avatars/**/source_project/
assets/avatars/**/Anchor.json
assets/avatars/Version*/
assets/avatars/version*/
assets/avatars/*(broken)/
!assets/avatars/**/.gitkeep

